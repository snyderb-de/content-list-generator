.DS_Store
__pycache__/
*.pyc
/build/
/releases/linux/*
!releases/linux/.gitkeep
/releases/macos/*
!releases/macos/.gitkeep
/releases/windows-go/*
!releases/windows-go/.gitkeep
/releases/windows-python/*
!releases/windows-python/.gitkeep
/releases/windows-portable/*
!releases/windows-portable/.gitkeep
/testing/content-scan/generated/*
!/testing/content-scan/generated/.gitkeep
/testing/email-copy/generated/*
!/testing/email-copy/generated/.gitkeep
/testing/manual-output/*
!/testing/manual-output/.gitkeep
/testing/manual-samples/*
!/testing/manual-samples/.gitkeep

# Wails frontend build artifacts
/frontend/node_modules/
/frontend/dist/*
!/frontend/dist/gitkeep

# Local test and design assets should stay untracked
*_test.go
/python/tests/
/testing/
/project-dashboard/
/design/
CLAUDE.md
.claude/settings.local.json
